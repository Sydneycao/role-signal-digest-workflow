APIFY_TOKEN=your_apify_token_here

# Required when SCORING_MODE=gemini. Create a key in Google AI Studio.
# The default Gemini model has a free API tier in supported regions.
GEMINI_API_KEY=
SCORING_MODE=gemini
LLM_MAX_POSTS_PER_RUN=5
GEMINI_MAX_OUTPUT_TOKENS=256
LLM_POST_CHAR_LIMIT=3000
OUTREACH_MODE=template

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_TO=recipient@example.com

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_KEY=your_supabase_anon_key_here

# Optional overrides
GEMINI_MODEL=gemini-3.5-flash-lite
SCORE_THRESHOLD=7
MAX_RESULTS=20
APIFY_MAX_RESULTS_PER_QUERY=25
APIFY_MAX_QUERIES_PER_RUN=2
APIFY_MAX_TOTAL_RESULTS_PER_RUN=50
APIFY_MAX_PAID_DATASET_ITEMS=50
APIFY_DAYS_LOOKBACK=7
APIFY_DRY_RUN=false
APIFY_ACTOR_ID=harvestapi/linkedin-post-search
APIFY_MAX_RESULTS_INPUT_FIELD=maxPosts
APIFY_POSTED_LIMIT=week
FEEDBACK_BASE_URL=https://your-project-ref.supabase.co/functions/v1/role-feedback
FEEDBACK_FORM_URL=https://your-github-username.github.io/job-search-agent/feedback.html
